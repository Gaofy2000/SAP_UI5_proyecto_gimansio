<mvc:View
    controllerName="com.inetum.becapractica.controller.FormAlumno"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
>
    <Page
        id="formAlumno"
        title="{i18n>FormularioAlumnoSubtitle}"
    >
        <content>
            <IconTabBar
                class="sapUiResponsiveContentPadding"
            >
                <items>
                    <IconTabFilter
                        icon="sap-icon://hint"
                        key="info"
                    >
                        <core:Fragment
                            fragmentName="com.inetum.becapractica.fragments.AlumnoDisplayForm"
                            type="XML"
                        />
                        <core:Fragment
                            fragmentName="com.inetum.becapractica.fragments.AlumnoEditForm"
                            type="XML"
                        />
                    </IconTabFilter>
                    <IconTabFilter
                        icon="sap-icon://attachment"
                        key="attachments"
                        count="3"
                    >
                    </IconTabFilter>
                    <IconTabFilter
                        icon="sap-icon://notes"
                        key="notes"
                        count="12"
                    >
                        <Text text="Notes go here ..." />
                    </IconTabFilter>
                    <IconTabFilter
                        icon="sap-icon://group"
                        key="people"
                    >
                        <Text text="People content goes here ..." />
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </content>
    </Page>
</mvc:View>
